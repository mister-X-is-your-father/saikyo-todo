# ================================================================
# saikyo-todo: Caddy 逆プロキシ設定 (社内 LAN / 社内ドメイン想定)
# ================================================================
# ドメインを持つ場合は http:// を実 FQDN に差し替えて自動 TLS を受ける。
# 完全社内なら http:// のままで OK (Caddy は HTTP 継続可)。
# ================================================================

{
  # email your-admin@example.com  # 社内ドメインで TLS が必要なら有効化
  # auto_https off                # TLS 不要 (社内のみ HTTP) なら有効化
}

:80 {
  reverse_proxy web:3001
  encode zstd gzip
  log {
    output stdout
    format console
  }
}
