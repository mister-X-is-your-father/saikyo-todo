# docker-compose --env-file .env.production で使う。
# 値はコピー後に埋める。.env.production は .gitignore に入っている前提。

# Postgres 接続 (Supabase 本体または自前 postgres)
DATABASE_URL=postgresql://postgres:your-password@postgres:5432/postgres

# Supabase クライアント用
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-host
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Agent 実行に必須)
ANTHROPIC_API_KEY=sk-ant-...
